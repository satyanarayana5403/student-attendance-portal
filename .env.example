# Database Configuration
# For SQLite (default):
# DATABASE_URL=sqlite:///attendance.db

# For MySQL:
# Replace placeholders with your actual MySQL 8.0 credentials
# FORMAT: mysql+pymysql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/attendance_db

# Flask Secret Key (change this in production!)
SECRET_KEY=your-secret-key-change-me

# Gmail SMTP (for sending absent notifications)
# Use App Password — not your main password
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password
